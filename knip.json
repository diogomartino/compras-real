{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "**/dist/**",
    "**/node_modules/**",
    "**/data/**",
    "**/*.tsbuildinfo",
    "apps/server/src/db/migrations/**"
  ],
  "workspaces": {
    "apps/client": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/server": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/db": {
      "project": ["src/**/*.ts"]
    },
    "packages/email": {
      "entry": ["index.tsx", "emails/**/*.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/logger": {
      "project": ["src/**/*.ts"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"]
    }
  }
}
