{
  "name": "@myapp/client",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "eslint ./src --ext ts,tsx",
    "lint:fix": "eslint ./src --ext ts,tsx --report-unused-disable-directives --fix",
    "check-types": "tsc --noEmit --project tsconfig.app.json",
    "format": "prettier --write \"**/*.ts*\" --config ./.prettierrc.json",
