{
  "name": "@myapp/server",
  "version": "0.0.0",
  "module": "/src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./src/index.ts",
    "db:gen": "bunx drizzle-kit generate --dialect postgresql --schema ../../packages/db/src/schema.ts --out ./src/db/migrations",
    "format": "prettier --write \"**/*.ts*\" --config ./.prettierrc.json",
    "lint": "eslint ./src/**/*.ts --ext ts --report-unused-disable-directives",
    "lint:fix": "eslint ./src/**/*.ts --ext ts --report-unused-disable-directives --fix",
    "check-types": "tsc --noEmit",
    "magic": "bun --bun run lint:fix && bun --bun run format && bun --bun run check-types"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.56.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.1.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@myapp/db": "workspace:*",
    "@myapp/email": "workspace:*",
    "@myapp/logger": "workspace:*",
    "@myapp/shared": "workspace:*",
    "@trpc/server": "11.18.0",
    "chalk": "^5.6.2",
    "cron": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "playwright-extra": "^4.3.6",
    "postgres": "^3.4.9",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^6.14.0",
    "superjson": "^2.2.5",
    "trpc-bun-adapter": "^1.3.2",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
